<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demolistview.controllers.AppControlers">


         <children>
            <Label text="Lista de personas" />
            <GridPane prefHeight="165.0" prefWidth="600.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints maxHeight="32.0" minHeight="0.0" prefHeight="32.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="40.0" minHeight="0.0" prefHeight="40.0" vgrow="SOMETIMES" />
            <RowConstraints maxHeight="40.0" minHeight="0.0" prefHeight="40.0" vgrow="SOMETIMES" />
                  <RowConstraints maxHeight="20.0" minHeight="0.0" prefHeight="0.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="Nombre" />
                  <Label prefHeight="12.0" prefWidth="55.0" text="Email" GridPane.rowIndex="1" />
                  <TextField fx:id="txtName" prefHeight="45.0" prefWidth="302.0" GridPane.columnIndex="1" />

                  <TextField fx:id="txtEmail" prefHeight="53.0" prefWidth="308.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label text="Edad" GridPane.rowIndex="2" />
            <TextField fx:id="txtEdad" GridPane.columnIndex="1" GridPane.rowIndex="2" />
               </children>
            </GridPane>
            <HBox prefHeight="90.0" prefWidth="600.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#onReload" prefHeight="30.0" prefWidth="68.0" text="Recargar" />
                  <Button mnemonicParsing="false" onAction="#onAdd" prefHeight="25.0" prefWidth="69.0" text="Agregar" />
               </children>
            </HBox>
            <ListView fx:id="listView" prefHeight="115.0" prefWidth="494.0" />
             <Label fx:id="lblMsg" layoutX="21.0" layoutY="241.0" text="Label" />


   </children>
</VBox>
